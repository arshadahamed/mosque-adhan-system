{
  "name": "mawaqit-platform",
  "private": true,
  "engines": { "node": ">=20" },
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @mawaqit/api db:migrate",
    "db:seed": "pnpm --filter @mawaqit/api db:seed"
  }
}
