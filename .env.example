# ============================================================
# Mawaqit Platform — environment template
# Copy to .env and fill in real values (see docs/DATABASE.md).
# ============================================================

NODE_ENV=development
PORT=4000

# --- Supabase Postgres ---------------------------------------
# Runtime (pooled / PgBouncer, port 6543). Get the exact host from
# Supabase Dashboard → Connect → "Connection pooling".
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Migrations only (direct, port 5432).
DIRECT_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# --- Supabase API / Storage ----------------------------------
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Upstash Redis (rate-limit / cache / OTP) ----------------
# Leave blank in dev to use the in-memory fallback.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Auth ----------------------------------------------------
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
COOKIE_DOMAIN=localhost
WEB_ORIGIN=http://localhost:3000

# --- Email (SMTP) --------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Mawaqit <no-reply@mawaqit.app>"

# --- Optional integrations -----------------------------------
RECAPTCHA_SECRET=
WEATHER_API_KEY=
